        <!-- horizontal_fov = 2.0 * arctan(width / (2.0 * focalLength)) -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>B8G8R8</format>
        </image>
        <clip>
          <near>0.2</near>
          <far>100.0</far>
        </clip>
        <lens>
          <!-- type element is mandatory -->
          <type>custom</type>
          <!-- manually defined mapping function r = c1*f*fun(theta/c2 + c3) -->
          <!-- More information here: https://en.wikipedia.org/wiki/Fisheye_lens#Mapping_function -->
          <custom_function>
            <c1>1.05</c1>
            <!-- linear scaling -->
            <c2>4</c2>
            <!-- angle scaling -->
            <f>1.0</f>
            <!-- one more scaling parameter -->
            <fun>tan</fun>
            <!-- one of sin,tan,id -->
          </custom_function>
          <!-- if it is set to `true` your horizontal FOV will ramain as defined -->
          <!-- othervise it depends on lens type and custom function, if there is one -->
          <scale_to_hfov>true</scale_to_hfov>
          <!-- clip everything that is outside of this angle -->
          <cutoff_angle>3.1415</cutoff_angle>
          <!-- resolution of the cubemap texture, the highter it is - the sharper is your image -->
          <env_texture_size>512</env_texture_size>
        </lens>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="camera_controller">
        <robotNamespace/>
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>head/insta360/camera</cameraName>
        <imageTopicName>color/image_raw</imageTopicName>
        <cameraInfoTopicName>color/camera_info</cameraInfoTopicName>
        <frameName>/head/insta360/camera_color_optical_frame</frameName>
        <hackBaseline>0</hackBaseline>
      </plugin>
    </sensor>
  </gazebo>
  <!-- Camera -->
  <joint name="head/sr300/camera_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.105 0 0.10874"/>
    <parent link="head/link_tip"/>
    <child link="head/sr300/camera_link"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="head/sr300/camera_link">
  </link>
  <joint name="head/sr300/camera_color_frame_joint" type="fixed">
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0.02 0 0"/>
    <parent link="head/sr300/camera_link"/>
    <child link="head/sr300/camera_color_frame"/>
  </joint>
  <link name="head/sr300/camera_color_frame">
    </link>
  <joint name="head/sr300/camera_color_optical_frame_joint" type="fixed">
    <axis xyz="0 1 0"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
    <parent link="head/sr300/camera_color_frame"/>
    <child link="head/sr300/camera_color_optical_frame"/>
  </joint>
  <link name="head/sr300/camera_color_optical_frame">
    </link>
  <!-- camera -->
  <gazebo reference="head/sr300/camera_color_frame">
    <material>Gazebo/Black</material>
    <sensor name="head/sr300/camera" type="depth">
      <update_rate>30.0</update_rate>
      <camera name="head/sr300/camera">
        <horizontal_fov>0.927295218</horizontal_fov>
        <!-- horizontal_fov = 2.0 * arctan(width / (2.0 * focalLength)) -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>B8G8R8</format>
        </image>
        <clip>
          <near>0.2</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin filename="libgazebo_ros_openni_kinect.so" name="camera_plugin">
        <robotNamespace/>
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>head/sr300/camera</cameraName>
        <imageTopicName>color/image_raw</imageTopicName>
        <cameraInfoTopicName>color/camera_info</cameraInfoTopicName>
        <depthImageTopicName>aligned_depth_to_color/image_raw</depthImageTopicName>
        <depthImageCameraInfoTopicName>aligned_depth_to_color/camera_info</depthImageCameraInfoTopicName>
        <pointCloudTopicName>depth/points</pointCloudTopicName>
        <frameName>/head/sr300/camera_color_optical_frame</frameName>
        <pointCloudCutoff>0.2</pointCloudCutoff>
        <pointCloudCutoffMax>1.5</pointCloudCutoffMax>
        <hackBaseline>0</hackBaseline>
        <focalLength>0</focalLength>
        <CxPrime>0</CxPrime>
        <Cx>0</Cx>
        <!-- gazebo doesn't simulate Cx (rviz does). 0 means that Cx is center of width -->
        <Cy>0</Cy>
        <!-- gazebo doesn't simulate Cy (rviz does). 0 means that Cy is center of width -->
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
  <!-- head_link0 -->
